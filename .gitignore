# =============================================================================
# MedML-Ops .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
MANIFEST
.env
.venv/
venv/
env/
ENV/
pip-wheel-metadata/

# --- Testing & Coverage ---
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/

# --- Type Checking ---
.mypy_cache/
.dmypy.json
dmypy.json

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- MLflow ---
mlruns/
mlartifacts/

# --- Models (track large files with Git LFS) ---
models/
*.pkl
*.joblib
*.pt
*.pth
*.h5
*.ckpt

# --- Data (NEVER commit patient data) ---
data/
*.csv
*.parquet
*.feather
*.h5df
*.npy
*.npz

# --- DICOM (medical imaging — NEVER commit) ---
*.dcm
*.dicom
dicom_data/

# --- Reports & Compliance Output ---
# (Generated files — commit only templates, not outputs)
reports/*.html
reports/*.json
compliance/*.json
compliance/*.pdf
docs/model_card.html

# --- Logs ---
logs/
*.log
*.jsonl

# --- Docker ---
.dockerignore
docker-compose.override.yml

# --- Environment Variables ---
.env
.env.*
*.env

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Temporary ---
tmp/
temp/
*.tmp
*.bak

# --- Pre-commit ---
.pre-commit-config.yaml.bak

# Exceptions: keep these tracked
!.gitignore
!requirements.txt
!configs/*.yaml
!src/__init__.py
